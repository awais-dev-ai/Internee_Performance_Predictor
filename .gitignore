# Project specific data and models (ML/Data Science standard)
# Ignore all files in data/ and models/ directories except the directory structure (.gitkeep)
data/*
!data/.gitkeep
models/*
!models/.gitkeep
# Allow JSON metadata to be tracked for model versioning
!models/model_metadata.json
